{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ParaBank Account",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": { "type": "integer" },
      "customerId": { "type": "integer" },
      "type": { "type": "string", "enum": ["CHECKING", "SAVINGS", "LOAN"] },
      "balance": { "type": "number" }
    },
    "required": ["id", "customerId", "type", "balance"]
  }
}