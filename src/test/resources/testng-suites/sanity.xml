<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Sanity Suite" verbose="1">

    <listeners>
        <listener class-name="com.aliparmar.sdet.utils.ExtentTestListener"/>
    </listeners>

    <test name="Sanity Tests">
        <groups>
            <run>
                <include name="sanity"/>
            </run>
        </groups>
        <classes>
            <class name="com.aliparmar.sdet.api.ParaBankApiSmokeTest"/>
            <class name="com.aliparmar.sdet.db.ParaBankDbTest"/>
        </classes>
    </test>

</suite>