<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CI Suite" verbose="1">

    <!-- Runs the deterministic, no-browser tests for continuous integration. -->
    <listeners>
        <listener class-name="com.aliparmar.sdet.utils.ExtentTestListener"/>
    </listeners>

    <test name="API and Database Tests">
        <classes>
            <class name="com.aliparmar.sdet.api.ParaBankApiSmokeTest"/>
            <class name="com.aliparmar.sdet.db.ParaBankDbTest"/>
        </classes>
    </test>

</suite>