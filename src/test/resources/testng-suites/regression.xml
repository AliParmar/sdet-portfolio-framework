<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Suite" verbose="1">

    <listeners>
        <listener class-name="com.aliparmar.sdet.utils.ExtentTestListener"/>
    </listeners>

    <test name="Full Regression">
        <!-- No group filter: runs every test in the listed classes. -->
        <classes>
            <class name="com.aliparmar.sdet.tests.ParaBankSmokeTest"/>
            <class name="com.aliparmar.sdet.api.ParaBankApiSmokeTest"/>
            <class name="com.aliparmar.sdet.db.ParaBankDbTest"/>
        </classes>
    </test>

</suite>